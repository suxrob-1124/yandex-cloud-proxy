# =============================================================
#  Telegram monitoring (optional)
#
#  How to set up:
#    1. Create a bot: @BotFather -> /newbot -> copy the token
#    2. Create a private channel in Telegram
#    3. Add the bot to the channel as an administrator
#    4. Get the channel chat_id:
#       curl https://api.telegram.org/bot<TOKEN>/getUpdates
#       -> find "chat":{"id":-100...}
#    5. Copy this file:
#       cp telegram.yml.example telegram.yml
#    6. Fill in the values below
#    7. make install (or make sync-users)
#
#  If this file is missing — monitoring is not installed.
# =============================================================

telegram_bot_token: "YOUR_BOT_TOKEN"
telegram_chat_id: "YOUR_CHAT_ID"
